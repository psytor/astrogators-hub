# astrogators-hub — environment configuration
# Vite inlines these at BUILD time; rebuild after any change.
#
# Every URL goes through the workspace reverse proxy (nginx) so the whole
# product stays under one origin. That keeps cross-app navigation seamless,
# auth state (localStorage/cookies) shared, and avoids CORS on API calls.
# Only scheme + host differ between dev and prod.

# Astrogator's Table backend — auth + game-data API
# DEV:  http://localhost/astrogators-table
# PROD: https://astrotable.dynv6.net/astrogators-table
VITE_ASTROGATORS_TABLE_URL=http://localhost/astrogators-table
