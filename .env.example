# astrogators-hub — frontend configuration
#
# Vite inlines any var starting with VITE_ into the bundle at build time.
# URLs include the backend service prefix (dev and prod share the same URL shape).

# Astrogator's Table backend API
# DEV:  http://localhost:8000/astrogators-table
# PROD: https://yourdomain.com/astrogators-table
VITE_ASTROGATORS_TABLE_URL=http://localhost:8000/astrogators-table

# Mod Ledger UI (for cross-app navigation links)
# DEV:  http://localhost:5174
# PROD: https://yourdomain.com/mod-ledger
VITE_MOD_LEDGER_UI_URL=http://localhost:5174
